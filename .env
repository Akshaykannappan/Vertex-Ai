
# Your Google Cloud Project ID
# Find it at: console.cloud.google.com (shown at the top of the page)
GOOGLE_CLOUD_PROJECT=project-2d2fcb24-fa35-42f0-81f

# The corpus name you received after running setup_corpus.py
# Example: projects/123456789/locations/us-central1/ragCorpora/987654321
VERTEX_CORPUS_NAME=projects/project-2d2fcb24-fa35-42f0-81f/locations/us-west1/ragCorpora/6917529027641081856
# Region — do not change
LOCATION=us-west1

# Fix for gRPC DNS resolver bug on macOS
GRPC_DNS_RESOLVER=native
